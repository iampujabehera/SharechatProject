# --- Required ---

# OpenAI API key. Powers both /api/trending extraction and /api/summary.
# Get one at https://platform.openai.com/api-keys.
# OpenAI is paid from request 1 — add at least $5 of credit to your account.
OPENAI_API_KEY=

# --- Optional (enable richer signals) ---

# NewsAPI free tier: https://newsapi.org/register (100 reqs/day).
# If missing: NewsAPI source is silently skipped.
NEWSAPI_KEY=

# YouTube Data API v3 key from Google Cloud Console (free 10,000 units/day).
# If missing: YouTube source is silently skipped.
YOUTUBE_API_KEY=

# --- Tuning knobs (optional overrides) ---

# Switch the runtime model — defaults to gpt-4o-mini (cheapest, ~$0.005 per call).
# For higher quality, swap to gpt-4o (~20x more expensive but richer Hindi nuance).
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini
# OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Auto-detected on Vercel; only set for non-default localhost ports.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
